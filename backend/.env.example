# Scottish Mountain Weather API Environment Configuration
# Copy this file to .env and update the values for your environment

# Database Configuration
DATABASE_URL=postgresql://mountain_weather_user:your_password@localhost:5432/mountain_weather
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=3600
DB_CONNECT_TIMEOUT=30
DB_STATEMENT_TIMEOUT=30000
DB_SSL_MODE=prefer
DB_ECHO_SQL=false

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Security Configuration
REQUIRE_API_KEY=false
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# Weather Data Configuration
WEATHER_UPDATE_INTERVAL_HOURS=4
WEATHER_DATA_RETENTION_DAYS=730

# Application Configuration
API_TITLE=Scottish Mountain Weather API
API_VERSION=1.0.0
API_DESCRIPTION=Weather forecasting API for Scottish mountains
ENVIRONMENT=development
DEBUG=true

# CORS Configuration
ENABLE_CORS=true
ALLOWED_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_ALL_REQUESTS=false
LOG_BLOCKED_REQUESTS=true

# Cache Configuration
CACHE_WEATHER_DATA_MINUTES=240
CACHE_LOCATION_DATA_MINUTES=1440
CACHE_SEARCH_RESULTS_MINUTES=60

# External API Keys (optional)
# OWM_API_KEY=your_openweathermap_api_key

# Monitoring (optional)
# SENTRY_DSN=your_sentry_dsn
# PROMETHEUS_METRICS=true

# Production Settings (uncomment for production)
# ENVIRONMENT=production
# DEBUG=false
# REQUIRE_API_KEY=true
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# LOG_LEVEL=WARNING